{
  "manifest_version": 3,
  "name": "CARVIS Canvas Assistant",
  "version": "1.0.0",
  "short_name": "CARVIS",
  "author": "Carvis",
  "description": "AI assistant for Canvas LMS — deadlines, grades, voice commands, and page control right inside your school's Canvas.",
  "homepage_url": "https://carvis.app",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://carvis.app/extension/iframe*"
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "CARVIS"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.instructure.com/*"
      ],
      "js": [
        "contentScript.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_end"
    }
  ]
}
