generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                            String    @id @default(uuid())
  email                         String    @unique
  name                          String?
  image                         String?
  // Canvas OAuth — encrypted at rest
  canvasBaseUrl                 String?
  canvasAccessTokenEncrypted    String?
  canvasRefreshTokenEncrypted   String?
  canvasTokenExpiresAt          DateTime?
  canvasUserId                  String?
  // Legacy fields — keep for migration compatibility
  canvasToken                   String?
  canvasDomain                  String?
  // User preferences
  ttsEnabled                    Boolean   @default(true)
  proactiveAlerts               Boolean   @default(true)
  energyLevel                   Int       @default(3)
  createdAt                     DateTime  @default(now())
  updatedAt                     DateTime  @updatedAt

  courses       Course[]
  grades        Grade[]
  reminders     Reminder[]
  studyGroups   StudyGroupMember[]
  conversations Conversation[]
}

model Course {
  id            String   @id
  userId        String
  name          String
  code          String?
  color         String?
  enrollmentId  String?
  lastSynced    DateTime @default(now())

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignments Assignment[]
  materials   CourseMaterial[]
  grades      Grade[]
}

model Assignment {
  id          String    @id
  courseId    String
  name        String
  description String?   @db.Text
  dueDate     DateTime?
  points      Float?
  url         String?
  completed   Boolean   @default(false)

  course      Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

model CourseMaterial {
  id       String  @id
  courseId String
  name     String
  type     String
  url      String?
  content  String?
  vectorId String?

  course   Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

model Reminder {
  id           String   @id @default(uuid())
  userId       String
  assignmentId String?
  type         String
  triggeredAt  DateTime
  active       Boolean  @default(true)

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model StudyGroup {
  id          String   @id @default(uuid())
  courseId    String
  name        String
  description String?
  members     StudyGroupMember[]
}

model StudyGroupMember {
  userId   String
  groupId  String
  joinedAt DateTime @default(now())

  user    User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  group   StudyGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@id([userId, groupId])
}

model Conversation {
  id        String   @id @default(uuid())
  userId    String
  role      String
  message   String   @db.Text
  intent    String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Grade {
  id            String   @id @default(uuid())
  userId        String
  courseId      String
  currentScore  Float?
  finalScore    Float?
  letterGrade   String?
  fetchedAt     DateTime @default(now())

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}
