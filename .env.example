# Local development defaults. Copy to .env and adjust as needed.
USE_EMBEDDED_POSTGRES=true
POSTGRES_PORT=54329
POSTGRES_PASSWORD=password
POSTGRES_DB=jarvis

# Or point at your own Postgres instance instead:
# USE_EMBEDDED_POSTGRES=false
# DATABASE_URL=postgresql://user:pass@host:5432/jarvis

# 64-char hex string (32 bytes) for AES-256-GCM token encryption
ENCRYPTION_KEY=

# Optional: AI voice responses (falls back to rule-based without this)
# GROQ_API_KEY=

# Email (Resend) — required in production. When unset, OTP codes are logged
# to server stdout and NOT returned to clients, so signup flows still work
# for local dev. Set this for any non-dev environment.
# Get a key at https://resend.com/api-keys
# RESEND_API_KEY=re_xxx
# EMAIL_FROM=Carvis <hello@carvis.app>

API_PORT=8080
WEB_PORT=20034
BASE_PATH=/
APP_URL=http://localhost:20034

# Comma-separated origins allowed by CORS (production: set to your domain)
# ALLOWED_ORIGINS=https://yourdomain.com

# Canvas OAuth (optional — PAT auth works without these)
# CANVAS_CLIENT_ID=
# CANVAS_CLIENT_SECRET=

# Web-push notifications (VAPID keys). Generate with:
#   npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:hello@carvis.app

# Background schedulers — opt-in via env flag.
# CANVAS_SYNC_ENABLED=true runs sync-scheduler every 5 min (cooldown 15 min)
# REMINDER_SCHEDULER_ENABLED=true runs reminder-scheduler every 60 s
CANVAS_SYNC_ENABLED=true
REMINDER_SCHEDULER_ENABLED=true

# ============================================================================
# PRODUCTION / RENDER DEPLOYMENT
# ============================================================================
#
# 1. DATABASE: Do NOT use USE_EMBEDDED_POSTGRES in production.
#    Create a managed Postgres on Render (or Neon/Supabase) and set:
#      DATABASE_URL=postgresql://user:pass@host:5432/dbname
#
# 2. ALLOWED_ORIGINS: Must include your frontend URL or CORS will block
#    all requests. Example for Render:
#      ALLOWED_ORIGINS=https://jarvis-canvas.onrender.com
#    If the frontend is on Vercel, use that Vercel URL instead.
#
# 3. EXTENSION_DIR: Override the Chrome extension files path.
#    Default: process.cwd()/artifacts/chrome-extension
#    On Render this works as-is if you deploy the full monorepo.
#    For Docker/lean images without the chrome-extension dir, set:
#      EXTENSION_DIR=/path/to/chrome-extension
#    The download endpoint returns 404 if no files are found.
#
# 4. PORT: Render auto-sets the PORT env var. Don't override it.
#    The API server reads PORT at startup.
#
# 5. NODE_ENV: Set to "production" on Render. This enforces:
#    - RESEND_API_KEY must be set (no fake email)
#    - CORS must have ALLOWED_ORIGINS
#    - Stricter rate limiting
