{
  "manifest_version": 3,
  "name": "CARVIS Canvas Assistant",
  "version": "0.2.0",
  "description": "CARVIS on Canvas — AI assistant for deadlines, grades, voice commands, and page control right inside Canvas LMS",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://carvis.app/*"
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "CARVIS"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.instructure.com/*"
      ],
      "js": [
        "contentScript.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_end"
    }
  ]
}
